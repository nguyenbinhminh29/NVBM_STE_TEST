{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/v1/Products/{id:guid}/inventory"
        }
      },
      "inventory-subroute": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/v1/Products/{id:guid}/inventory/{**remainder}"
        }
      },
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/v1/Products"
        }
      },
      "catalog-subroute": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/v1/Products/{**remainder}"
        }
      },
      "barcode-route": {
        "ClusterId": "barcode-cluster",
        "Match": {
          "Path": "/api/v1/Barcodes"
        }
      },
      "barcode-subroute": {
        "ClusterId": "barcode-cluster",
        "Match": {
          "Path": "/api/v1/Barcodes/{**remainder}"
        }
      },
      "catalog-openapi-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/openapi/catalog.json"
        },
        "Transforms": [
          {
            "PathSet": "/openapi/v1.json"
          }
        ]
      },
      "barcode-openapi-route": {
        "ClusterId": "barcode-cluster",
        "Match": {
          "Path": "/openapi/barcode.json"
        },
        "Transforms": [
          {
            "PathSet": "/openapi/v1.json"
          }
        ]
      },
      "promotion-route": {
        "ClusterId": "promotion-cluster",
        "Match": {
          "Path": "/api/v1/Orders"
        }
      },
      "promotion-subroute": {
        "ClusterId": "promotion-cluster",
        "Match": {
          "Path": "/api/v1/Orders/{**remainder}"
        }
      },
      "shift-route": {
        "ClusterId": "shift-cluster",
        "Match": {
          "Path": "/api/v1/Shifts"
        }
      },
      "shift-subroute": {
        "ClusterId": "shift-cluster",
        "Match": {
          "Path": "/api/v1/Shifts/{**remainder}"
        }
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://catalog-api"
          }
        }
      },
      "barcode-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://barcode-api"
          }
        }
      },
      "promotion-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://promotion-api"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://inventory-api"
          }
        }
      },
      "shift-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://shift-api"
          }
        }
      }
    }
  }
}